r,false);window.__gpp_addFrame("__gppLocator")}})();</script><script id="didomi-consent-helpers" type="text/javascript">window.__consentHelpers = (function() {
  const DONOTSEL = 'donotsel-FK8jHZdx';
  const GDPR = 'gdpr';
  const NONE = 'none';
  const PERMUTIVE_LIMITED = 'permutive-9wAsbgwh';
  const PERMUTIVE_TECHNOLOGIES = 'permutive-GnePaW4N';

  function getRudderstackConsent({ purposes = {}, regulation }) {
    if (regulation !== GDPR) {
      const alwaysOptedIn = ['C0001', 'C0002', 'C0003'];
      const canOptOut = ['C0004', 'C0005'];
      const targetingAllowed = regulation === NONE || (purposes[DONOTSEL]?.enabled ?? true);
      return {
        allowedConsentIds: targetingAllowed
          ? [...alwaysOptedIn, ...canOptOut]
          : alwaysOptedIn,
        deniedConsentIds: targetingAllowed ? [] : canOptOut
      };
    }
    const allowedConsentIds = [];
    const deniedConsentIds = [];
    Object.values(purposes).forEach(function(purpose) {
      if (purpose.enabled) allowedConsentIds.push(purpose.id);
      else deniedConsentIds.push(purpose.id);
    });
    return { allowedConsentIds, deniedConsentIds };
  }

  function getPermutiveOptIn({ purposes = {}, regulation, vendors = {} }) {
    if (regulation === NONE) return true;
    if (regulation !== GDPR) return purposes[DONOTSEL]?.enabled ?? true;
    return vendors[PERMUTIVE_LIMITED]?.enabled && vendors[PERMUTIVE_TECHNOLOGIES]?.enabled;
  }

  let lastRudderstackConsent = null;
  function serializeRudderstackConsent({ allowedConsentIds, deniedConsentIds }) {
    return JSON.stringify({ allowed: [...allowedConsentIds].sort(), denied: [...deniedConsentIds].sort() });
  }

  return {
    applyGptPrivacySettings: function({ purposes = {}, regulation }) {
      if (regulation === GDPR || regulation === NONE) return;
      const optedOut = !(purposes[DONOTSEL]?.enabled ?? true);

      if (typeof googletag !== 'undefined' && googletag.cmd) {
        googletag.cmd.push(function() {
          googletag.pubads().setPrivacySettings({
            restrictDataProcessing: optedOut
          });
        });
      }
    },
    applyRudderstackConsent: function(userStatus) {
      if (!window.rudderanalytics?.consent) return;
      const consentManagement = getRudderstackConsent(userStatus);
      // Skip duplicate consent() calls (synchronous seed + consent.changed can repeat the same state).
      const serialized = serializeRudderstackConsent(consentManagement);
      if (serialized === lastRudderstackConsent) return;
      lastRudderstackConsent = serialized;
      window.rudderanalytics.consent({ trackConsent: true, consentManagement });
    },
    applyPermutiveConsent: function(userStatus) {
      if (!window.permutive?.consent) return;
      window.permutive.consent({
        opt_in: getPermutiveOptIn(userStatus),
        token: new Date().getTime().toLocaleString()
      });
    }
  };
})();</script><script id="didomi-onready" type="text/javascript">
            window.didomiOnReady = window.didomiOnReady || [];
            window.didomiOnReady.push(function(Didomi) {
              const userStatus = Didomi.getCurrentUserStatus();
              const needsConsentCollection = Didomi.shouldUserStatusBeCollected();
              const isGDPR = userStatus.regulation === 'gdpr';

              // Make sure we're not waiting for consent to be submitted (applies to GDPR users when cookie banner is present, but no selections have been submitted yet)
              if (isGDPR && needsConsentCollection && Didomi.notice.isVisible()) {
                return;
              }

              window.__consentHelpers.applyGptPrivacySettings(userStatus);
              window.dispatchEvent(new CustomEvent('didomi:ready', { detail: userStatus }));
            });
          </script><script id="didomi-footer-link-updates" type="text/javascript">
            window.didomiOnReady = window.didomiOnReady || [];
            window.didomiOnReady.push(function (Didomi) {

              // begin updates to provided code
              function updatePmLink() {
              // end updates to provided code
                var pmElement = document.getElementById('pmLink');//get the pmLink object
                
                // begin updates to provided code
                if(!pmElement) return false;
                // end updates to provided code
                
                var reg = Didomi.getCurrentUserStatus().regulation;//set to the user's regulation

                // Call other functions on the SDK
                if(reg==='ccpa'||reg==='cpra'){
                  pmElement.innerHTML = 'Your Privacy Choices <img src="data:image/svg+xml;base64," width="25" height="15"/>';
                }
                else if(reg==='gdpr'){
                  pmElement.innerHTML = 'Manage Settings';
                }
                else{
                  pmElement.style.display = 'none';
                }
                
                // begin updates to provided code
                return true;
              }
              // end updates to provided code

              // begin custom MutationObserver code
              // Footer loads async; poll for #pmLink if it's not in the DOM yet
              if(!updatePmLink()){
                var observer = new MutationObserver(function() {
                  if(updatePmLink()) observer.disconnect();
                });
                observer.observe(document.body, { childList: true, subtree: true });
              }
              // end custom MutationObserver code
            });
          </script><script id="didomi-consent-changed" type="text/javascript">
            window.didomiEventListeners = window.didomiEventListeners || [];
            window.didomiEventListeners.push({
              event: 'consent.changed',
              listener: function() {
                const userStatus = Didomi.getCurrentUserStatus();
                window.__consentHelpers.applyGptPrivacySettings(userStatus);
                window.__consentHelpers.applyRudderstackConsent(userStatus);
                window.__consentHelpers.applyPermutiveConsent(userStatus);
                window.dispatchEvent(new CustomEvent('didomi:consent-changed', { detail: userStatus }));
              }
            });
