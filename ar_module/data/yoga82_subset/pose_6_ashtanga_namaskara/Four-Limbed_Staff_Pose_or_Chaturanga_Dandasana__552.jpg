e645a19a550081.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/bb7469dce8dc2433.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\"],\"DeveloperTools\"]\n60:I[901019,[\"https://headless.yogajournal.com/_next/static/chunks/840844254684f8c8.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/d23f1a97844a5860.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/39e645a19a550081.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/bb7469dce8dc2433.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\"],\"StacksContext\"]\n61:I[506467,[\"https://headless.yogajournal.com/_next/static/chunks/840844254684f8c8.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/d23f1a97844a5860.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/39e645a19a550081.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/bb7469dce8dc2433.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\"],\"IframeProvider\"]\n62:I[867993,[\"https://headless.yogajournal.com/_next/static/chunks/840844254684f8c8.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/d23f1a97844a5860.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/39e645a19a550081.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/bb7469dce8dc2433.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\"],\"CapabilityGateProvider\"]\n64:I[435785,[\"https://headless.yogajournal.com/_next/static/chunks/840844254684f8c8.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/d23f1a97844a5860.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/39e645a19a550081.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/bb7469dce8dc2433.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\"],\"ErrorBoundary\"]\n65:I[278406,[\"https://headless.yogajournal.com/_next/static/chunks/840844254684f8c8.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/d23f1a97844a5860.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/39e645a19a550081.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/bb7469dce8dc2433.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\"],\"ArticleStacksClient\"]\n66:I[774634,[\"https://headless.yogajournal.com/_next/static/chunks/840844254684f8c8.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/d23f1a97844a5860.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/39e645a19a550081.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/bb7469dce8dc2433.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\"],\"PianoUpfrontEmailCollectionModalDiv\"]\n3b:[\"$\",\"$L5f\",null,{\"builtAt\":\"Wed, 15 Jul 2026 20:08:04 GMT\",\"children\":[[\"$\",\"$L60\",null,{\"children\":[\"$\",\"$L61\",null,{\"children\":[\"$\",\"$L62\",null,{\"children\":[\"$L63\",[\"$\",\"$L64\",null,{\"errorComponent\":null,\"children\":[\"$\",\"$3d\",null,{\"children\":[\"$\",\"$L65\",null,{\"url\":\"https://www.yogajournal.com/poses/two-fit-moms-6-tips-for-doing-yoga-with-your-kids/\",\"category\":\"Yoga Poses for Kids\",\"showSponsoredContent\":true}]}]}]]}]}]}],[\"$\",\"$L66\",null,{}]]}]\n"])</script><script>self.__next_f.push([1,"67:I[811371,[\"https://headless.yogajournal.com/_next/static/chunks/840844254684f8c8.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/d23f1a97844a5860.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/39e645a19a550081.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/bb7469dce8dc2433.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\"],\"AdContext\"]\n68:T1a99,"])</script><script>self.__next_f.push([1,"\u003cp\u003eKids, almost inevitably, can get in the way of a parent\u0026#8217;s yoga practice—in our case, quite literally. Since yoga is such a significant part of our lives, and we both generally practice at home, it was only natural for us to invite our children on the mat. It wasn’t a hard sell—our kids wanted to be a part of our yoga, which was great and very welcome.\u003c/p\u003e\n\u003cp\u003eIf our kids are any indication, we at \u003ca href=\"http://www.twofitmoms.com\" data-afl-p=\"0\"\u003eTwo Fit Moms\u003c/a\u003e think it’s likely that your kids would love to practice yoga with you. So this week, in honor of Mother\u0026#8217;s Day, we are offering 6 tips for doing yoga with your kids.\u003c/p\u003e\n\u003ch3\u003e1. Focus on the basics.\u003c/h3\u003e\n\u003cfigure class=\"pom-image-wrap alignnone\"\u003e\u003cimg decoding=\"async\" title=\"Masumi doing Tree Pose with her kids.\" src=\"https://www.yogajournal.com/wp-content/uploads/2016/05/masumi-doing-tree-pose-with-her-kids.jpg?width=730\" alt=\"Masumi doing Tree Pose with her kids.\" /\u003e\u003c/figure\u003e\n\u003cp\u003eKids love \u003ca href=\"https://www.yogajournal.com/pose/downward-facing-dog/\" data-afl-p=\"0\"\u003eDownward-Facing Dog\u003c/a\u003e, \u003ca href=\"https://www.yogajournal.com/pose/tree-pose/\" data-afl-p=\"0\"\u003eTree Pose\u003c/a\u003e, \u003ca href=\"https://www.yogajournal.com/pose/warrior-ii-pose/\" data-afl-p=\"0\"\u003eWarrior II\u003c/a\u003e, and \u003ca href=\"https://www.yogajournal.com/pose/easy-pose/\" data-afl-p=\"0\"\u003eEasy Pose\u003c/a\u003e. These are great beginner poses, in general.\u003c/p\u003e\n\u003cp\u003eTree Pose is a great single-leg balance to practice with your children. Hold hands to link your trees together and create a forest. This is a fun way to help your kids balance while building their confidence in their abilities.\u003c/p\u003e\n\u003ch3\u003e2. Let them surprise you.\u003c/h3\u003e\n\u003cfigure class=\"pom-image-wrap alignnone\"\u003e\u003cimg decoding=\"async\" title=\"Laura doing yoga with her daughter.\" src=\"https://www.yogajournal.com/wp-content/uploads/2016/05/laura-doing-yoga-with-her-daughter.jpg?width=730\" alt=\"Laura doing yoga with her daughter.\" /\u003e\u003c/figure\u003e\n\u003cp\u003eTeach them what they should be doing, and don’t fret if their poses aren\u0026#8217;t perfect. Your kids may surprise you. This AcroYoga pose with my daughter did exactly that—I never expected her to get into this posture, and I don’t think she expected to either!\u003c/p\u003e\n\u003cp\u003eYoga with my daughter is all about having fun. But in between the giggles, I see glimmers of her own practice taking shape, which is very exciting for me to watch.\u003c/p\u003e\n\u003cp\u003e\u003cem\u003eSee also\u003c/em\u003e\u003ca href=\"https://www.yogajournal.com/slideshow/two-fit-moms-grounding-gravity-defying-earth-day-yoga-poses/\" data-afl-p=\"0\"\u003eTwo Fit Moms’ Gravity-Defying Earth Day Flow\u003c/a\u003e\u003c/p\u003e\n\u003ch3\u003e3. Play with animal poses.\u003c/h3\u003e\n\u003cfigure class=\"pom-image-wrap alignnone\"\u003e\u003cimg decoding=\"async\" title=\"Masumi Goldman doing Camel Pose with her kids.\" src=\"https://www.yogajournal.com/wp-content/uploads/2016/05/masumi-goldman-doing-camel-pose-with-her-kids.jpg?width=730\" alt=\"Masumi Goldman doing Camel Pose with her kids.\" /\u003e\u003c/figure\u003e\n\u003cp\u003eConsider focusing on the animal-named poses like \u003ca href=\"https://www.yogajournal.com/pose/camel-pose/\" data-afl-p=\"0\"\u003eCamel\u003c/a\u003e, Butterfly (\u003ca href=\"https://www.yogajournal.com/poses/bound-angle-pose-2/ \" data-afl-p=\"0\"\u003eBound Angle Pose\u003c/a\u003e), \u003ca href=\"https://www.yogajournal.com/poses/cobra-pose-2/ \" data-afl-p=\"0\"\u003eCobra\u003c/a\u003e, \u003ca href=\"https://www.yogajournal.com/pose/cat-pose/\" data-afl-p=\"0\"\u003eCat\u003c/a\u003e/\u003ca href=\"https://www.yogajournal.com/pose/cow-pose/\" data-afl-p=\"0\"\u003eCow\u003c/a\u003e, etc. These postures will resonate with them and are ones that will allow them to be more playful and silly.\u003c/p\u003e\n\u003cp\u003eCamel Pose is a challenging backbend, but the good news is that it can be modified for kids in the same way that it can be modified for adults. Begin in a kneeling position with the thighs perpendicular to the floor, place your hands onto your lower back, fingers pointed down. Lift your chest and create an even backbend, avoiding collapsing into the lower back. If your children would like to attempt the full expression of the pose, encourage them to first try the pose with their toes tucked and heels lifted. Slowly reach one hand back at a time to hold each heel. If that goes well, they can try the version with toes untucked. Whichever version they attempt, just make sure that they are safe and having a good time.\u003c/p\u003e\n\u003cp\u003e\u003cem\u003eSee also\u003c/em\u003e\u003ca href=\"https://www.yogajournal.com/slideshow/two-fit-moms-backbending-practice/\" data-afl-p=\"0\"\u003eTwo Fit Moms’ Backbending Practice\u003c/a\u003e\u003c/p\u003e\n\u003ch3\u003e4. Add modifications to make it extra fun.\u003c/h3\u003e\n\u003cfigure class=\"pom-image-wrap alignnone\"\u003e\u003cimg decoding=\"async\" title=\"Laura Kasperzak of Two Fit Moms doing yoga with her daughter.\" src=\"https://www.yogajournal.com/wp-content/uploads/2016/05/laura-kasperzak-of-two-fit-moms-doing-yoga-with-her-daughter.jpg?width=730\" alt=\"Laura Kasperzak of Two Fit Moms doing yoga with her daughter.\" /\u003e\u003c/figure\u003e\n\u003cp\u003eKids are naturally flexible so they love \u003ca href=\"https://www.yogajournal.com/poses/cobra-pose-2/ \" data-afl-p=\"0\"\u003eCobra Pose\u003c/a\u003e—especially if you ask them to try to touch their toes to their head! Partnering with mom makes it extra fun.\u003c/p\u003e\n\u003cp\u003e\u003cem\u003eSee also\u003c/em\u003e\u003ca href=\"https://www.yogajournal.com/slideshow/two-fit-moms-heart-opening-partner-yoga/\" data-afl-p=\"0\"\u003eTwo Fit Moms’ Heart-Opening Partner Yoga Sequence\u003c/a\u003e\u003c/p\u003e\n\u003ch3\u003e5. Don\u0026#8217;t expect them to do a full practice.\u003c/h3\u003e\n\u003cfigure class=\"pom-image-wrap alignnone\"\u003e\u003cimg decoding=\"async\" title=\"Masumi Goldman's kids doing Tree Pose.\" src=\"https://www.yogajournal.com/wp-content/uploads/2016/05/masumi-goldmans-kids-doing-tree-pose.jpg?width=730\" alt=\"Masumi Goldman's kids doing Tree Pose.\" /\u003e\u003c/figure\u003e\n\u003cp\u003eWe know this sounds obvious, but when our kids started to join us, we thought they would just fall in love with yoga and practice for a full 30–45 minutes. WRONG. Children under the age of 10 do not typically have the attention span, but they can manage 5–10 minutes on the mat. So, start with small intervals of time.\u003c/p\u003e\n\u003cp\u003e\u003cem\u003eSee also\u003c/em\u003e\u003ca href=\"https://www.yogajournal.com/slideshow/good-morning-yoga-poses-jumpstart-kids-day/\" data-afl-p=\"0\"\u003eGood Morning Yoga: A 3-Minute Flow to Jumpstart Your Kids’ Day\u003c/a\u003e\u003c/p\u003e\n\u003ch3\u003e6. Get them their own yoga gear.\u003c/h3\u003e\n\u003cfigure class=\"pom-image-wrap alignnone\"\u003e\u003cimg decoding=\"async\" title=\"Laura Kasperzak's kids practice yoga on Gaiam yoga mats for kids.\" src=\"https://www.yogajournal.com/wp-content/uploads/2016/05/laura-kasperzaks-kids-practice-yoga-on-gaiam-yoga-mats-for-kids.jpg?width=730\" alt=\"Laura Kasperzak's kids practice yoga on Gaiam yoga mats for kids.\" /\u003e\u003c/figure\u003e\n\u003cp\u003eWe don’t know about your kids, but ours love to have their own space and their own stuff. Fun \u003ca href=\"https://www.yogajournal.com/lifestyle/kids-yoga-mats/\" data-afl-p=\"0\"\u003eyoga mats for kids\u003c/a\u003e will make your little ones feel grown up—and you won’t have to share your mat!\u003c/p\u003e\n"])</script><script>self.__next_f.push([1,"69:Td62,"])</script><script>self.__next_f.push([1,"Kids, almost inevitably, can get in the way of a parent\u0026#8217;s yoga practice—in our case, quite literally. Since yoga is such a significant part of our lives, and we both generally practice at home, it was only natural for us to invite our children on the mat. It wasn’t a hard sell—our kids wanted to be a part of our yoga, which was great and very welcome.\nIf our kids are any indication, we at Two Fit Moms think it’s likely that your kids would love to practice yoga with you. So this week, in honor of Mother\u0026#8217;s Day, we are offering 6 tips for doing yoga with your kids.\n1. Focus on the basics.\n\nKids love Downward-Facing Dog, Tree Pose, Warrior II, and Easy Pose. These are great beginner poses, in general.\nTree Pose is a great single-leg balance to practice with your children. Hold hands to link your trees together and create a forest. This is a fun way to help your kids balance while building their confidence in their abilities.\n2. Let them surprise you.\n\nTeach them what they should be doing, and don’t fret if their poses aren\u0026#8217;t perfect. Your kids may surprise you. This AcroYoga pose with my daughter did exactly that—I never expected her to get into this posture, and I don’t think she expected to either!\nYoga with my daughter is all about having fun. But in between the giggles, I see glimmers of her own practice taking shape, which is very exciting for me to watch.\nSee alsoTwo Fit Moms’ Gravity-Defying Earth Day Flow\n3. Play with animal poses.\n\nConsider focusing on the animal-named poses like Camel, Butterfly (Bound Angle Pose), Cobra, Cat/Cow, etc. These postures will resonate with them and are ones that will allow them to be more playful and silly.\nCamel Pose is a challenging backbend, but the good news is that it can be modified for kids in the same way that it can be modified for adults. Begin in a kneeling position with the thighs perpendicular to the floor, place your hands onto your lower back, fingers pointed down. Lift your chest and create an even backbend, avoiding collapsing into the lower back. If your children would like to attempt the full expression of the pose, encourage them to first try the pose with their toes tucked and heels lifted. Slowly reach one hand back at a time to hold each heel. If that goes well, they can try the version with toes untucked. Whichever version they attempt, just make sure that they are safe and having a good time.\nSee alsoTwo Fit Moms’ Backbending Practice\n4. Add modifications to make it extra fun.\n\nKids are naturally flexible so they love Cobra Pose—especially if you ask them to try to touch their toes to their head! Partnering with mom makes it extra fun.\nSee alsoTwo Fit Moms’ Heart-Opening Partner Yoga Sequence\n5. Don\u0026#8217;t expect them to do a full practice.\n\nWe know this sounds obvious, but when our kids started to join us, we thought they would just fall in love with yoga and practice for a full 30–45 minutes. WRONG. Children under the age of 10 do not typically have the attention span, but they can manage 5–10 minutes on the mat. So, start with small intervals of time.\nSee alsoGood Morning Yoga: A 3-Minute Flow to Jumpstart Your Kids’ Day\n6. Get them their own yoga gear.\n\nWe don’t know about your kids, but ours love to have their own space and their own stuff. Fun yoga mats for kids will make your little ones feel grown up—and you won’t have to share your mat!"])</script><script>self.__next_f.push([1,"63:[\"$\",\"$L64\",null,{\"errorComponent\":null,\"children\":[\"$\",\"div\",null,{\"className\":\"article-template w-full text-center\",\"data-post-analytics-data\":\"{\\\"authors\\\":[\\\"Masumi Goldman\\\",\\\"Laura Kasperzak\\\"],\\\"categories\\\":[\\\"Yoga Poses\\\",\\\"The Yoga for You\\\"],\\\"tags\\\":[\\\"kids and yoga\\\",\\\"Two Fit Moms\\\"],\\\"domain\\\":\\\"yoga-journal\\\",\\\"post_uuid\\\":\\\"e54a8e719f4b97a0386214588e3e82c9\\\",\\\"publish_date\\\":\\\"May 5, 2016\\\",\\\"title\\\":\\\"6 Tips for Doing Yoga With Your Kids\\\"}\",\"children\":[\"$\",\"$L67\",null,{\"page\":0,\"targeting\":{\"adCategories\":[],\"isSponsored\":false,\"displayAffiliateLinkDisclaimer\":false,\"displayType\":\"Dense\",\"title\":\"6 Tips for Doing Yoga With Your Kids\",\"authors\":[{\"name\":\"Masumi Goldman\",\"id\":4645,\"url\":\"https://www.yogajournal.com/byline/masumi-goldman\"},{\"name\":\"Laura Kasperzak\",\"id\":6631,\"url\":\"https://www.yogajournal.com/byline/laura-kasperzak\"}],\"url\":\"https://www.yogajournal.com/poses/two-fit-moms-6-tips-for-doing-yoga-with-your-kids/\",\"categoryStructure\":[\"Yoga Poses\",\"The Yoga for You\"],\"createdDate\":\"2022-11-07T20:17:58.514Z\",\"sourceUuid\":\"e54a8e719f4b97a0386214588e3e82c9\",\"denormalizedTags\":[\"kids and yoga\",\"Two Fit Moms\"],\"hasTextToSpeech\":false,\"tags\":[{\"name\":\"kids and yoga\",\"slug\":\"kids-and-yoga\"},{\"name\":\"Two Fit Moms\",\"slug\":\"two-fit-moms\"}],\"overrideRecirc\":false,\"recircArticleOverrides\":null,\"review\":{},\"contentModules\":null,\"publicationDate\":\"2016-05-05T19:53:13.000Z\",\"disableAds\":false,\"type\":\"article\",\"sourceId\":\"700\",\"content\":\"$68\",\"disablePrerollAds\":false,\"heroVideo\":null,\"mainVideo\":null,\"mainVideoContextualLocation\":\"off\",\"imageUrl\":\"https://www.yogajournal.com/wp-content/uploads/2016/05/masumi-goldman-doing-camel-pose-with-her-kids.jpg\",\"imageCredit\":null,\"imageWidth\":800,\"imageHeight\":450,\"imageCaption\":null,\"imageAltText\":\"Masumi Goldman doing Camel Pose with her kids.\",\"distOriginalPostUrl\":null,\"subTitle\":\"If our kids are any indication, we at Two Fit Moms think it’s likely that your kids want to practice yoga with you. So this week, in honor of Mother's Day, we are offering our best tips for making it work.\",\"dek\":\"\",\"showArticleDate\":true,\"editorUpdatedDate\":null,\"distOriginalSiteName\":null,\"sponsorName\":null,\"updatedDate\":\"2026-01-09T14:07:36.810Z\",\"sqImageUrl\":\"\",\"contentItem\":{\"categoryName\":\"Yoga Poses for Kids\",\"bodyContent\":\"$69\"},\"seoTitle\":\"Two Fit Moms: 6 Tips for Doing Yoga With Kids | Yoga for Kids\",\"seoMetaDescription\":\"6 tips for doing yoga with your kids from Two Fit Moms, from animal poses to AcroYoga.\",\"editor\":\"\",\"cluster\":\"\",\"flexibleLayouts\":null,\"utcPublicationDate\":null,\"corrections\":null},\"children\":[\"$L6a\",\"$L6b\",\"$L6c\",\"$L6d\",\"$L6e\",\"$L6f\",\"$L70\"]}]}]}]\n"])</script><script>self.__next_f.push([1,"71:I[785754,[\"https://headless.yogajournal.com/_next/static/chunks/840844254684f8c8.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/d23f1a97844a5860.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/39e645a19a550081.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/bb7469dce8dc2433.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\"],\"PermutiveScript\"]\n73:I[834005,[\"https://headless.yogajournal.com/_next/static/chunks/840844254684f8c8.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/d23f1a97844a5860.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/39e645a19a550081.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/bb7469dce8dc2433.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\"],\"AdPrestitial\"]\n74:I[599419,[\"https://headless.yogajournal.com/_next/static/chunks/840844254684f8c8.js?dpl=dpl_9TGXkioRwxWPFY5xG1igJLeTKnmB\",\"https://headless.yogajournal.com/_next/static/chunks/d23f1a97844a5860.js?dpl=dpl_9TGXkioRwxWPFY5xG1